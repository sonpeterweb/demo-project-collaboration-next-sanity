
APP_URL='http://localhost:3000' ## required — canonical site URL for SEO and sitemap

GITHUB_ID='your github client ID' ## required for NextAuth admin panel
GITHUB_SECRET='your github secret ID' ## required for NextAuth admin panel

NEXTAUTH_SECRET='your next-auth secret' ## required — generate at https://generate-secret.vercel.app/32
NEXTAUTH_URL='http://localhost:3000' ## required for localhost only

SANITY_API_READ_TOKEN='sanity api token' ## optional — required for preview/draft mode
SANITY_PREVIEW_SECRET='preview secret' ## optional — required in production to enable draft preview via /api/preview
SANITY_REVALIDATE_SECRET='webhook secret' ## optional — required for /api/revalidate webhook
SANITY_STUDIO_HOST='flowspacestudio' ## optional — hostname for hosted Studio (*.sanity.studio)
NEXT_PUBLIC_SANITY_PROJECT_ID='sanity project id'
NEXT_PUBLIC_SANITY_DATASET='production'
